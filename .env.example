# Agnes API Key 配置示例
#
# v3.1.2 推荐：把真实 key 放到 XDG 全局路径
#   ~/.config/openclaw/agnes-free-video.env （600 权限）
# 这样不会被 skill 目录的 git/sync/backup 误带走。本文件留作占位符即可。
#
# 脚本优先级（自动合并去重）：环境变量 > XDG 文件 > 本 .env
#
# 用法（三种任选，推荐 XDG）：
#   方式 A（推荐）：XDG 全局
#     mkdir -p ~/.config/openclaw && chmod 700 ~/.config/openclaw
#     cat > ~/.config/openclaw/agnes-free-video.env <<EOF
#     AGNES_API_KEY=sk-xxx
#     EOF
#     chmod 600 ~/.config/openclaw/agnes-free-video.env
#
#   方式 B：skill 本地 .env（向后兼容）
#     1. 复制本文件为 .env：cp .env.example .env
#     2. 编辑 .env 写入你的真实 key：AGNES_API_KEY=sk-你的key
#     3. 设 600 权限：chmod 600 .env
#     4. 注入到当前 shell：set -a && source ./.env && set +a
#
#   方式 C：环境变量（一次性）
#     export AGNES_API_KEY='sk-xxx'
#
# 多个 key 逗号分隔（自动轮换，提升 quota）：
#   AGNES_API_KEY=sk-key1,sk-key2,sk-key3
#
# 自定义 API base（一般不用改，调试时可指向代理）：
#   AGNES_API_BASE=https://apihub.agnes-ai.com

AGNES_API_KEY=sk-请把这里替换成你的Agnes API Key

# 备选名：`AGNES_TOKEN=sk-xxx` 也可用，跟 AGNES_API_KEY 完全等价
# （脚本同时认两者；优先级：env var > XDG 文件 > 本 .env）
